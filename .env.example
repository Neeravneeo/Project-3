# ============================================================
# AI Trading Platform — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- App ---
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-random-64-char-string
DEBUG=true

# --- Database (PostgreSQL + TimescaleDB) ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=trading
POSTGRES_USER=trading_user
POSTGRES_PASSWORD=change-me

# Constructed by app (do not edit)
DATABASE_URL=postgresql+asyncpg://trading_user:change-me@db:5432/trading

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Broker: Alpaca (US Markets) ---
# Get keys from https://alpaca.markets → paper trading dashboard
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_SECRET_KEY=your-alpaca-secret-key
ALPACA_PAPER=true   # set to false for live trading

# --- Broker: Zerodha Kite (Indian Markets) ---
KITE_API_KEY=your-kite-api-key
KITE_API_SECRET=your-kite-api-secret
KITE_ACCESS_TOKEN=your-daily-access-token   # refreshed each trading day

# --- AI / LLM ---
# Google Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# OpenAI (optional fallback)
OPENAI_API_KEY=your-openai-api-key

# LangSmith (agent monitoring): https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=trading-platform

# --- JWT Auth ---
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440   # 24 hours

# --- Market Data ---
# Alpha Vantage (optional supplemental data)
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# Polygon.io (production US data — upgrade from Alpaca free tier)
POLYGON_API_KEY=your-polygon-api-key

# --- Risk Defaults (all configurable per user) ---
MAX_DRAWDOWN_TRIGGER=0.05        # 5% portfolio drawdown → hedge
MAX_POSITION_BETA=0.90           # portfolio beta > 0.9 → hedge
SINGLE_POSITION_LOSS_TRIGGER=0.03  # 3% single position loss → alert
VIX_CAUTION_LEVEL=20
VIX_HEDGE_LEVEL=25
VIX_AGGRESSIVE_LEVEL=30
MAX_POSITION_WEIGHT=0.10         # max 10% single position

# --- Celery Beat Schedule (seconds) ---
MARKET_DATA_REFRESH_INTERVAL=60
SIGNAL_GENERATION_INTERVAL=300
RISK_MONITORING_INTERVAL=60

# --- CORS ---
FRONTEND_URL=http://localhost:3000

# --- Monitoring ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
FLOWER_PORT=5555
